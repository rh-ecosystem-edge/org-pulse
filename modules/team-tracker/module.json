{
  "name": "People & Teams",
  "slug": "team-tracker",
  "description": "People, teams, delivery metrics, and org insights",
  "icon": "users-round",
  "order": 0,
  "disabled": true,
  "client": {
    "entry": "./client/index.js",
    "sotuWidgets": [
      {
        "id": "managed-teams",
        "name": "Managed Teams",
        "description": "Team cards for managers showing direct reports and components",
        "component": "./client/widgets/ManagedTeamsWidget.vue",
        "defaultSize": "full",
        "icon": "UsersRound",
        "category": "teams",
        "requireRole": "manager"
      },
      {
        "id": "my-teams",
        "name": "My Teams",
        "description": "Your team memberships with speciality and components",
        "component": "./client/widgets/MyTeamsWidget.vue",
        "defaultSize": "half",
        "icon": "Users",
        "category": "teams"
      },
      {
        "id": "quick-links",
        "name": "Quick Links",
        "description": "Navigation shortcuts to Manager Dashboard, Team Directory, and People",
        "component": "./client/widgets/QuickLinksWidget.vue",
        "defaultSize": "half",
        "icon": "Link2",
        "category": "navigation"
      },
      {
        "id": "person-lookup",
        "name": "Person Lookup",
        "description": "Search for a person by name and jump to their profile",
        "component": "./client/widgets/PersonLookupWidget.vue",
        "defaultSize": "half",
        "icon": "Search",
        "category": "navigation"
      }
    ],
    "navItems": [
      { "id": "home", "label": "Team Directory", "icon": "Users", "default": true },
      { "id": "people", "label": "People", "icon": "User" },
      { "id": "reports", "label": "Reports", "icon": "BarChart3" },
      { "id": "org-dashboard", "label": "Org Dashboard", "icon": "Building2" },
      { "id": "manager-dashboard", "label": "My Teams", "icon": "LayoutDashboard", "requireRole": "manager", "requireCondition": "in-app-mode" },
      { "id": "manage", "label": "Manage", "icon": "Settings", "requireRole": "team-admin", "requireCondition": "in-app-mode" }
    ],
    "settingsComponent": "./client/components/TeamTrackerSettings.vue"
  },
  "server": {
    "entry": "./server/index.js"
  },
  "defaultEnabled": true,
  "requires": [],
  "secrets": {
    "platform": ["jira", "github", "gitlab", "ipa", "google"],
    "module": [],
    "dynamic": {
      "pattern": "GITLAB_*_TOKEN",
      "description": "Per-instance GitLab tokens configured via Settings UI (gitlabInstances)"
    }
  },
  "export": {
    "files": [
      { "path": "team-data/registry.json", "notes": "People registry (lifecycle, identities, enrichment)" },
      { "path": "team-data/field-definitions.json", "notes": "Custom field definitions (person and team)" },
      { "path": "people/*.json", "notes": "Per-person Jira metrics" },
      { "path": "github-contributions.json", "notes": "GitHub contribution counts" },
      { "path": "github-history.json", "notes": "Monthly GitHub history" },
      { "path": "gitlab-contributions.json", "notes": "GitLab contribution counts" },
      { "path": "gitlab-history.json", "notes": "Monthly GitLab history" },
      { "path": "snapshots/**/*.json", "notes": "Team snapshots" },
      { "path": "jira-name-map.json", "notes": "Jira accountId cache" },
      { "path": "org-roster/teams-metadata.json", "notes": "Team boards and org structure" },
      { "path": "org-roster/components.json", "notes": "Component-to-team mapping" },
      { "path": "org-roster/rfe-backlog.json", "notes": "RFE backlog by team and component" }
    ]
  }
}
